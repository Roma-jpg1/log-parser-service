{
  "info": {
    "_postman_id": "7d8b3d50-7cd7-4f4d-b5d4-log-parser-service",
    "name": "Log Parser Service",
    "description": "API tests for the Go log parser service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "archive_path",
      "value": "data/log.zip"
    },
    {
      "key": "log_id",
      "value": "1"
    },
    {
      "key": "node_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('health body is OK', function () {",
              "  pm.expect(pm.response.text()).to.eql('OK');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Parse archive",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"path\": \"{{archive_path}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/parse/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "parse",
            ""
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('parse returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('parse returns log_id', function () {",
              "  pm.expect(body.log_id).to.be.a('number');",
              "});",
              "",
              "pm.collectionVariables.set('log_id', body.log_id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get log",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/log/{{log_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "log",
            "{{log_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get log returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('log status is success', function () {",
              "  pm.expect(body.status).to.eql('success');",
              "});",
              "",
              "pm.test('log has counters', function () {",
              "  pm.expect(body.nodes_count).to.be.a('number');",
              "  pm.expect(body.ports_count).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get topology",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/topology/{{log_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "topology",
            "{{log_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get topology returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('topology has nodes groups and edges', function () {",
              "  pm.expect(body.nodes).to.be.an('array');",
              "  pm.expect(body.groups).to.be.an('object');",
              "  pm.expect(body.edges).to.be.an('array');",
              "});",
              "",
              "if (body.nodes.length > 0) {",
              "  pm.collectionVariables.set('node_id', body.nodes[0].id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get node",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/node/{{node_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "node",
            "{{node_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get node returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('node response has node and info', function () {",
              "  pm.expect(body.node).to.be.an('object');",
              "  pm.expect(body.info).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get ports",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/port/{{node_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "port",
            "{{node_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get ports returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('ports response has ports', function () {",
              "  pm.expect(body.ports).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
